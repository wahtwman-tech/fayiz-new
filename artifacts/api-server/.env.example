# Server Configuration
PORT=3000
NODE_ENV=production

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/database

# Session/JWT Secret (REQUIRED)
SESSION_SECRET=your-super-secret-key-change-in-production

# Cache Webhook Secret (REQUIRED for cache invalidation)
# This token will be used by the admin panel to clear the cache
# IMPORTANT: Use a strong, random string in production!
# Example: openssl rand -base64 32
CACHE_WEBHOOK_SECRET=your-cache-webhook-secret-change-in-production
